// Power Platform dev container template
// Docs: https://github.com/TALXIS/tools-agentbox/tree/master/src/templates/power-platform
{
    "name": "Power Platform",

    // Use the pre-built image for fast startup (~30s), or comment out and use features for flexibility
    "image": "ghcr.io/talxis/tools-agentbox/image:latest",

    // Alternatively, build from scratch using community + custom features:
    // "image": "mcr.microsoft.com/dotnet/sdk:10.0",
    // "features": {
    //     "ghcr.io/devcontainers/features/git:1": {},
    //     "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    //     "ghcr.io/devcontainers/features/azure-cli:1": { "version": "latest", "extensions": "azure-devops" },
    //     "ghcr.io/devcontainers/features/powershell:1": { "version": "latest" },
    //     "ghcr.io/devcontainers/features/terraform:1": { "version": "latest" },
    //     "ghcr.io/devcontainers/features/github-cli:1": { "version": "latest" },
    //     "ghcr.io/devcontainers/features/copilot-cli:1": { "version": "latest" },
    //     "ghcr.io/jlaundry/devcontainer-features/azure-functions-core-tools:1": {},
    //     "ghcr.io/talxis/tools-agentbox/pac-cli:1": { "version": "latest" },
    //     "ghcr.io/talxis/tools-agentbox/txc-cli:1": { "version": "latest" }
    // },

    "customizations": {
        "vscode": {
            "extensions": [
                // .NET / C#
                "ms-dotnettools.csdevkit",
                "ms-dotnettools.vscode-dotnet-runtime",
                // Power Platform
                "microsoft-IsvExpTools.powerplatform-vscode",
                // Azure
                "ms-vscode.azurecli",
                "ms-azuretools.vscode-azurefunctions",
                // GitHub
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "GitHub.vscode-github-actions",
                "GitHub.vscode-pull-request-github",
                // General
                "ms-vscode.powershell",
                "hashicorp.terraform",
                "redhat.vscode-yaml",
                "editorconfig.editorconfig"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": true,
                "dotnet.defaultSolution": "disable",
                // TXC MCP Server — exposed to VS Code Copilot Chat
                // dnx downloads and runs TALXIS.CLI.MCP on demand (no pre-install needed)
                "mcp": {
                    "servers": {
                        "TALXIS CLI": {
                            "type": "stdio",
                            "command": "dnx",
                            "args": ["TALXIS.CLI.MCP", "--yes"]
                        }
                    }
                }
            }
        },
        "codespaces": {
            // Auto-open the welcome guide when first starting the Codespace
            "openFiles": [
                "README.md"
            ]
        }
    },

    // Auto-run on container start: keep pac + txc + devkit templates up to date
    "postStartCommand": {
        "update-pac": "[ -f /etc/devcontainer-pac-cli/auto-update ] && dotnet tool update --tool-path /usr/local/bin Microsoft.PowerApps.CLI.Tool 2>/dev/null || true",
        "update-txc": "dotnet tool update --tool-path /usr/local/bin TALXIS.CLI 2>/dev/null || true",
        "update-devkit-templates": "dotnet new install TALXIS.DevKit.Templates.Dataverse 2>/dev/null || true"
    },

    "postCreateCommand": "echo '✅ Power Platform dev container ready.'",

    // Minimum machine spec — 2 CPUs / 8 GB for free Codespaces tier (60 hrs/month)
    "hostRequirements": {
        "cpus": 2,
        "memory": "8gb",
        "storage": "32gb"
    },

    "forwardPorts": [
        // Azure Functions local runtime
        7071,
        // Azurite blob storage
        10000,
        // Azurite queue storage
        10001,
        // Azurite table storage
        10002
    ],

    "portsAttributes": {
        "7071": {
            "label": "Azure Functions",
            "onAutoForward": "notify"
        },
        "10000": {
            "label": "Azurite (Blob)",
            "onAutoForward": "silent"
        },
        "10001": {
            "label": "Azurite (Queue)",
            "onAutoForward": "silent"
        },
        "10002": {
            "label": "Azurite (Table)",
            "onAutoForward": "silent"
        }
    },

    "remoteEnv": {
        // Ensure dotnet global tools are on PATH
        "PATH": "${containerEnv:PATH}:${containerEnv:HOME}/.dotnet/tools"
    }
}
